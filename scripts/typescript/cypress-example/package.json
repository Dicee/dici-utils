  "scripts": {
    "build": "npm run lint && tsc -p tsconfig.json",
    "lint": "eslint cypress/**/*.ts --quiet --fix",
    "clean": "rm -rf build/ node_modules/",
    "release": "npm run build && cp -r node_modules cypress cypress.json package.json package-lock.json build",
    "cypress:build-and-open": "npm run build && cypress open",
    "cypress:build-and-run": "npm run build && cypress run",
    "cypress:open": "bin/run_with_settings cypress:build-and-open",
    "cypress:run": "bin/run_with_settings cypress:build-and-run"
  },
  "dependencies": {
    "cypress": "6.3.0",
    "cypress-image-snapshot": "^4.0.1",
    "cypress-pipe": "^2.0.0",
    "pdf-parse": "^1.1.1"
  },
  "devDependencies": {
    "typescript": "^4.0.3",
    "@typescript-eslint/eslint-plugin": "^3.0.2",
    "@typescript-eslint/parser": "^3.0.2",
    "eslint": "^7.1.0",
    "eslint-config-prettier": "^6.11.0",
    "eslint-plugin-prettier": "^3.1.3",
    "eslint-plugin-cypress": "^2.8.1",
    "prettier": "^2.0.5",
    "cypress-terminal-report": "^2.4.0",
    "@js-joda/core": "^3.2.0",
    "@js-joda/timezone": "^2.5.0"
  }
}